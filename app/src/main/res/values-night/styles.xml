<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="SettingsButtonStyle" parent="Widget.AppCompat.Button.Borderless">
        <item name="layout_constraintWidth">match_parent</item>
        <item name="android:layout_height">@dimen/settings_item_height</item>
        <item name="android:textAlignment">textStart</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="iconGravity">end</item>
        <item name="iconTint">@color/white</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
    </style>
    <style name="ActionBackStyle">
        <item name="srcCompat">@drawable/action_back_dark</item>
        <item name="android:padding">17dp</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>
    <style name="ActivityTitleStyle">
        <item name="android:paddingHorizontal">26dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
    </style>
    <style name="SearchStyle">
        <item name="android:layout_gravity">center</item>
        <item name="android:drawableStart">@drawable/icon_search</item>
        <item name="android:drawablePadding">18dp</item>
        <item name="android:ems">10</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:hint">@string/search</item>
        <item name="android:inputType">text</item>
        <item name="android:maxLines">1</item>
        <item name="android:background">@null</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/black</item>
    </style>
    <style name="SearchClearStyle">
        <item name="srcCompat">@drawable/clear_search_dark</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>
    <style name="OpenInNextActivityIconStyle">
        <item name="srcCompat">@drawable/action_on_next_activity_dark</item>
    </style>
    <style name="TrackNameSearchStyle">
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="TrackDetailsSearchStyle">
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="srcCompat">@drawable/separator_round_dark</item>
    </style>
    <style name="ButtonStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:backgroundTint">@color/white</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
    </style>
    <style name="ErrorSearchStyle">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">19sp</item>
    </style>
    <style name="YouSearchedStyle">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">19sp</item>
    </style>
</resources>