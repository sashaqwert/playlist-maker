<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="MainButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingVertical">24dp</item>
        <item name="android:paddingHorizontal">@dimen/padding_horizontal_button_main</item>
        <item name="android:gravity">center</item>
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">8dp</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="iconTint">@color/black</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:shadowRadius">0</item>
    </style>
    <style name="SettingsButtonStyle" parent="Widget.AppCompat.Button.Borderless">
        <item name="layout_constraintWidth">match_parent</item>
        <item name="android:layout_height">@dimen/settings_item_height</item>
        <item name="android:textAlignment">textStart</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/black</item>
        <item name="iconGravity">end</item>
        <item name="iconTint">@android:color/darker_gray</item>
    </style>
    <style name="ActionBackStyle">
        <item name="srcCompat">@drawable/action_back</item>
        <item name="android:padding">12dp</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>
    <style name="ActivityTitleStyle">
        <item name="android:paddingHorizontal">26dp</item>
        <item name="android:paddingVertical">5dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">22sp</item>
    </style>
</resources>