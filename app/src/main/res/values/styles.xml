<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="MainButtonStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingVertical">24dp</item>
        <item name="android:paddingHorizontal">@dimen/padding_horizontal_button_main</item>
        <item name="android:gravity">center</item>
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">8dp</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="iconTint">@color/black</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:shadowRadius">0</item>
    </style>
    <style name="SettingsButtonStyle" parent="Widget.AppCompat.Button.Borderless">
        <item name="layout_constraintWidth">match_parent</item>
        <item name="android:layout_height">@dimen/settings_item_height</item>
        <item name="android:textAlignment">textStart</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/black</item>
        <item name="iconGravity">end</item>
        <item name="iconTint">@android:color/darker_gray</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
    </style>
    <style name="ActionBackStyle">
        <item name="android:padding">17dp</item>
        <item name="srcCompat">@drawable/action_back</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>
    <style name="ActivityTitleStyle">
        <item name="android:paddingHorizontal">26dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
    </style>
    <style name="SearchStyle">
        <item name="android:layout_gravity">center</item>
        <item name="android:drawableStart">@drawable/search_input_icon</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:ems">10</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textSize">16sp</item>
        <item name="android:hint">@string/search</item>
        <item name="android:inputType">text</item>
        <item name="android:maxLines">1</item>
        <item name="android:background">@null</item>
    </style>
    <style name="SearchClearStyle">
        <item name="srcCompat">@drawable/clear_search</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>
    <style name="OpenInNextActivityIconStyle">
        <item name="srcCompat">@drawable/action_on_next_activity</item>
    </style>
    <style name="TrackNameSearchStyle">
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="TrackDetailsSearchStyle">
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@android:color/darker_gray</item>
        <item name="srcCompat">@drawable/separator_round</item>
    </style>
    <style name="RefreshButtonStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:backgroundTint">@color/black</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>